<?xml version="1.0" encoding="UTF-8"?>
<routes>

    <!-- Vehicle Types -->
    <vType id="car" accel="2.6" decel="4.5" length="5"
           maxSpeed="13.9" sigma="0.5"/>

    <vType id="emergency" accel="3.5" decel="5.0" length="5"
           maxSpeed="20.0" sigma="0.3"
           priority="10" vClass="emergency"/>

    <!-- Routes -->
    <route id="north_south" edges="n2c c2s"/>
    <route id="south_north" edges="s2c c2n"/>
    <route id="east_west" edges="e2c c2w"/>
    <route id="west_east" edges="w2c c2e"/>

    <!-- Regular traffic -->
    <flow id="flow_ns" type="car" route="north_south"
          begin="0" end="1000" vehsPerHour="400"/>

    <flow id="flow_sn" type="car" route="south_north"
          begin="0" end="1000" vehsPerHour="400"/>

    <flow id="flow_ew" type="car" route="east_west"
          begin="0" end="1000" vehsPerHour="300"/>

    <flow id="flow_we" type="car" route="west_east"
          begin="0" end="1000" vehsPerHour="300"/>

    <!-- Emergency Vehicles -->
    <vehicle id="ambulance_1" type="emergency"
             route="north_south" depart="50"/>

    <vehicle id="ambulance_2" type="emergency"
             route="east_west" depart="200"/>

</routes>